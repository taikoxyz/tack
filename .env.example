# Server
PORT=3000

# IPFS / data
IPFS_API_URL=http://ipfs:5001
# Optional replica Kubo RPC URLs (comma-separated). When set, pin/unpin calls are
# mirrored best-effort to each replica after the primary pin succeeds.
PIN_REPLICA_IPFS_API_URLS=
# Optional public delegate URLs matching the replica list above 1:1.
# These are returned in PinStatus.delegates alongside DELEGATE_URL.
PIN_REPLICA_DELEGATE_URLS=
IPFS_TIMEOUT_MS=30000
DATABASE_PATH=./data/tack.db
DELEGATE_URL=http://localhost:8080/ipfs

# Networking / security
# Recommended in production so the AgentCard and x402 metadata always use your
# canonical public HTTPS origin, even if proxy headers are missing or partial.
PUBLIC_BASE_URL=
# When false, rate limiting ignores forwarded headers and uses socket remote address.
# Set true only when running behind a trusted reverse proxy that sets forwarded client IP/host/proto headers.
TRUST_PROXY=false
# Comma-separated proxy IPs or CIDRs that are allowed to supply forwarded headers.
# Leave empty to fail closed and ignore forwarded headers even if TRUST_PROXY=true.
TRUSTED_PROXY_CIDRS=
# Required secret used to mint and verify short-lived owner bearer tokens.
# Paid `POST /pins` and `POST /upload` responses return `x-wallet-auth-token`
# headers that clients can use on owner routes.
WALLET_AUTH_TOKEN_SECRET=change-me
WALLET_AUTH_TOKEN_ISSUER=tack
WALLET_AUTH_TOKEN_AUDIENCE=tack-owner-api
WALLET_AUTH_TOKEN_TTL_SECONDS=900

# Upload and gateway limits
UPLOAD_MAX_SIZE_BYTES=104857600
GATEWAY_MAX_CONTENT_SIZE_BYTES=52428800
GATEWAY_CACHE_MAX_SIZE_BYTES=104857600
GATEWAY_CACHE_CONTROL_MAX_AGE_SECONDS=31536000
RATE_LIMIT_REQUESTS_PER_MINUTE=120

# Private object storage (wallet-owned bytes, not IPFS)
# IMPORTANT: in production, point PRIVATE_STORAGE_PATH at a persistent volume.
# The default lives inside the container and is destroyed on restart.
PRIVATE_STORAGE_PATH=./data/private-objects
PRIVATE_OBJECT_MAX_SIZE_BYTES=104857600

# SIWE wallet login for returning agents (POST /auth/challenge, /auth/token)
# Comma-separated CAIP-2 networks that may issue SIWE challenges. Defaults to
# Taiko Alethia + Base when unset. Add Tempo (eip155:4217) here if MPP smart
# contract wallets should authenticate.
WALLET_AUTH_ALLOWED_NETWORKS=eip155:167000,eip155:8453
# Optional EIP-1271 RPC endpoints for smart contract wallets. Format:
# "<caip2>=<rpc-url>,<caip2>=<rpc-url>". Without an RPC for a network,
# only EOA signatures verify on that network.
WALLET_AUTH_EIP1271_RPC_URLS=

# x402 payments
X402_FACILITATOR_URL=https://facilitator.taiko.xyz
X402_NETWORK=eip155:167000

# Settlement wallets — one per chain. Production startup rejects placeholders.
# These are three independent addresses. The same private key may control all
# three if they're all EOAs, but a Safe (or any contract wallet) on one chain
# does NOT automatically exist at the same address on the others — CREATE2
# addresses are deterministic but the contract must actually be deployed on
# each chain you use. Confirm each wallet is controllable on its chain before
# going to production.
X402_TAIKO_PAY_TO=0x0000000000000000000000000000000000000001
X402_BASE_PAY_TO=0x0000000000000000000000000000000000000001

# Asset config (Taiko USDC)
X402_USDC_ASSET_ADDRESS=0x0000000000000000000000000000000000000001
X402_USDC_ASSET_DECIMALS=6

# Pricing for paid endpoints (linear: max(min, sizeGB * rate * durationMonths))
X402_RATE_PER_GB_MONTH_USD=0.10
X402_MIN_PRICE_USD=0.001
X402_MAX_PRICE_USD=50.0
X402_DEFAULT_DURATION_MONTHS=1
X402_MAX_DURATION_MONTHS=24

# MPP (Machine Payment Protocol) on Tempo
# Optional. Set a strong random secret (32+ bytes) to enable MPP alongside x402.
MPP_SECRET_KEY=
# MPP settlement wallet on Tempo (required when MPP_SECRET_KEY is set).
MPP_PAY_TO=0x0000000000000000000000000000000000000001
# Use Tempo testnet (Moderato) instead of mainnet. Default: false.
MPP_TESTNET=false
# Override the Tempo RPC URL. Defaults to the public mainnet / Moderato endpoint
# from the viem `tempo` / `tempoModerato` chain definitions. Required only if you
# run against a private RPC — the service uses this client to re-read the
# on-chain Transfer event and derive the verified payer wallet for MPP charges.
MPP_TEMPO_RPC_URL=
